# Security headers — applied to every response Apache serves from this dir.
<IfModule mod_headers.c>
  Header set Content-Security-Policy "default-src 'self'; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; worker-src 'self'; manifest-src 'self'; font-src 'self' data:; connect-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header set X-Frame-Options "DENY"
  # `always` covers error responses too. Skip `preload` until HTTPS has been
  # stable for a few weeks — preload is a one-way door (max-age >= 2yr).
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  # Belt-and-braces with the <meta name="robots"> tags + robots.txt: this
  # header reaches crawlers that ignore HTML and fetch raw assets too.
  Header set X-Robots-Tag "noindex, nofollow, noarchive, nosnippet, noimageindex"
</IfModule>

# Long-cache hashed Vite assets (JS / CSS / fonts / images).
<FilesMatch "\.(js|mjs|css|woff2?|svg|png|jpg|jpeg|webp|ico)$">
  <IfModule mod_headers.c>
    Header set Cache-Control "public, max-age=31536000, immutable"
  </IfModule>
</FilesMatch>

# HTML shell, the service worker, and the PWA manifest must always be
# re-fetched so a deploy is picked up immediately. The SW file in particular
# MUST NOT be long-cached or the auto-update flow stalls.
<FilesMatch "\.html$|^sw\.js$|^registerSW\.js$|^workbox-.*\.js$|\.webmanifest$">
  <IfModule mod_headers.c>
    Header set Cache-Control "no-cache, must-revalidate"
  </IfModule>
</FilesMatch>

# Compress text assets if the host enables mod_deflate.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# Disable directory listings.
Options -Indexes

# Send 404 for dotfiles people might probe for.
<FilesMatch "^\.">
  Require all denied
</FilesMatch>
