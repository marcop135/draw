{
  "name": "draw-marcopontili-com",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "description": "Free whiteboard: Excalidraw with LaTeX (KaTeX), Mermaid-to-shapes, sanitized Markdown; PNG/JPEG/SVG/PDF export. React + TypeScript + Vite PWA; static, no backend or login.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prebuild": "node scripts/sync-readme-banner.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:ci": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "postinstall": "node scripts/ensure-playwright.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "capture:readme": "npm run build && playwright test --config=playwright.readme.config.ts",
    "capture:readme-gif": "npm run build && playwright test --config=playwright.readme-gif.config.ts && node scripts/webm-to-readme-gif.mjs"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "dompurify": "^3.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.11",
    "marked": "^18.0.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.4",
    "vite-plugin-pwa": "^1.2.0",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "jsdom": "^26.1.0"
  },
  "overrides": {
    "dompurify": "^3.4.1",
    "nanoid": "^5.1.9",
    "uuid": "^14.0.0",
    "esbuild": "^0.25.0",
    "lodash-es": "^4.18.1",
    "serialize-javascript": "^7.0.5"
  }
}
