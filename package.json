{
  "name": "draw-marcopontili-com",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "description": "Free whiteboard: Excalidraw with LaTeX (KaTeX), Mermaid-to-shapes, sanitized Markdown; PNG/JPEG/SVG/PDF export. React + TypeScript + Vite PWA; static, no backend or login.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "assets:brand": "node scripts/render-brand-assets.mjs",
    "lint": "eslint . --max-warnings=0",
    "lint:ci": "eslint . --max-warnings=0",
    "format": "prettier --write .",
    "postinstall": "node scripts/ensure-playwright.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "capture:readme": "npm run build && playwright test --config=playwright.readme.config.ts",
    "capture:readme-gif": "npm run build && playwright test --config=playwright.readme-gif.config.ts && node scripts/webm-to-readme-gif.mjs"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@excalidraw/mermaid-to-excalidraw": "^2.2.2",
    "@fontsource/roboto": "^5.2.10",
    "@phosphor-icons/react": "^2.1.10",
    "dompurify": "^3.4.1",
    "jspdf": "^4.2.1",
    "katex": "^0.16.11",
    "marked": "^15.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@types/katex": "^0.16.7",
    "@types/node": "^25.6.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "dompurify": "^3.4.1",
    "nanoid": "^5.1.9",
    "uuid": "^14.0.0",
    "esbuild": "^0.25.0",
    "lodash-es": "^4.18.1",
    "serialize-javascript": "^7.0.5"
  }
}
